# Local development — copy to .env and fill in real values
PORT=3000
FRONTEND_URL=http://127.0.0.1:4050
# CORS 允许多个前端域名，逗号分隔（不设则仅用 FRONTEND_URL）
# ALLOWED_ORIGINS=http://127.0.0.1:4050,https://your-app.vercel.app

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://127.0.0.1:4050/api/auth/google/callback

JWT_SECRET=replace-with-a-long-random-string
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

DATABASE_PATH=./data/app.db

X_CLIENT_ID=your-x-client-id
X_CLIENT_SECRET=your-x-client-secret
X_REDIRECT_URI=http://127.0.0.1:4050/api/auth/x/callback

TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_BOT_USERNAME=your_bot_username

RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=onboarding@resend.dev

# --- Render production (set in Render Dashboard, not in .env) ---
# NODE_ENV=production
# DATABASE_PATH=/data/app.db
# FRONTEND_URL=https://your-app.vercel.app
# ALLOWED_ORIGINS=https://your-app.vercel.app,https://forecast-frenzy-hub.lovable.app
# GOOGLE_REDIRECT_URI=https://your-app.vercel.app/api/auth/google/callback
# X_REDIRECT_URI=https://your-app.vercel.app/api/auth/x/callback
