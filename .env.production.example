# Render 生产环境 — 复制到 Render Dashboard → Environment Variables
# 使用「Add from .env」粘贴，勿提交含真实密钥的文件到 Git

NODE_ENV=production
ENABLE_PNPM=true

# 前端域名（Vercel），不要末尾斜杠
FRONTEND_URL=https://third-party-frontend-git-main-bcsx.vercel.app
ALLOWED_ORIGINS=https://third-party-frontend-git-main-bcsx.vercel.app,https://third-party-frontend.vercel.app

# 生产密钥（首次部署用 Generate 生成；已部署请保留原值，勿随意更换）
JWT_SECRET=replace-with-a-long-random-string
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# 免费 Render 实例不要设 DATABASE_PATH=/data/app.db（无持久磁盘）
# 留空或删除 DATABASE_PATH，代码会自动使用 ./data/app.db

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://third-party-frontend-git-main-bcsx.vercel.app/api/auth/google/callback

X_CLIENT_ID=your-x-client-id
X_CLIENT_SECRET=your-x-client-secret
X_REDIRECT_URI=https://third-party-frontend-git-main-bcsx.vercel.app/api/auth/x/callback

TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_BOT_USERNAME=your_bot_username

RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=onboarding@resend.dev
